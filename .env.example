# .env - Variables de Entorno para Docker Compose
# Copiar a .env.local para valores locales personalizados

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123456
POSTGRES_DB=proyect1_db

# Backend - ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5156
CONNECTION_STRING=Host=postgres;Port=5432;Database=proyect1_db;Username=admin;Password=admin123456
CORS_ORIGINS=http://localhost,http://localhost:80,http://frontend

# Frontend - Angular/Nginx
API_URL=http://backend:5156/api
